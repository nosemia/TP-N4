#include <iostream>
#include <vector>

using namespace std;

void cargarVector(vector<int> &v)
{
    for(int i = 0; i < 5; i++)
    {
        cout << "Ingrese un numero: ";
        cin >> v[i];
    }
}

void mostrarVector(vector<int> v)
{
    for(int i = 0; i < 5; i++)
    {
        cout << v[i] << " ";
    }

    cout << endl;
}

int main()
{
    vector<int> vec(5);

    cargarVector(vec);
    mostrarVector(vec);

    return 0;
}
