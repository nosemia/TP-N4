#include <iostream>
#include <vector>

using namespace std;

void cargarVector(vector<int> &v)
{
    for(int i = 0; i < 10; i++)
    {
        cout << "Ingrese un numero: ";
        cin >> v[i];
    }
}

bool estaOrdenado(vector<int> v)
{
    for(int i = 0; i < 9; i++)
    {
        if(v[i] > v[i + 1])
        {
            return false;
        }
    }

    return true;
}

int main()
{
    vector<int> numeros(10);

    cargarVector(numeros);

    if(estaOrdenado(numeros))
    {
        cout << "El vector esta ordenado de menor a mayor." << endl;
    }
    else
    {
        cout << "El vector no esta ordenado." << endl;
    }

    return 0;
}
