#include <iostream>
#include <vector>

using namespace std;

void procesarVector(vector<int> v)
{
    int sumaTotal = 0;
    int sumaMayores36 = 0;
    int mayores50 = 0;

    for(int i = 0; i < v.size(); i++)
    {
        sumaTotal += v[i];

        if(v[i] > 36)
        {
            sumaMayores36 += v[i];
        }

        if(v[i] > 50)
        {
            mayores50++;
        }
    }

    cout << "Suma total: " << sumaTotal << endl;
    cout << "Suma de los mayores a 36: " << sumaMayores36 << endl;
    cout << "Cantidad de valores mayores a 50: " << mayores50 << endl;
}

int main()
{
    vector<int> numeros(8);

    for(int i = 0; i < 8; i++)
    {
        cout << "Ingrese un numero: ";
        cin >> numeros[i];
    }

    procesarVector(numeros);

    return 0;
}
